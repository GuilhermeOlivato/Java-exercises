<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" style="-fx-padding: 20; -fx-background-color: #2b2b2b;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.demo.HelloController">

    <TextField fx:id="display" editable="false"
               style="-fx-font-size: 24px; -fx-background-color: #1e1e1e; -fx-text-fill: white; -fx-padding: 10;"
               prefHeight="60"/>

    <GridPane hgap="10" vgap="10">

        <!-- Row 0 -->
        <Button text="7" onAction="#handleNumber" GridPane.columnIndex="0" GridPane.rowIndex="0" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #3c3f41; -fx-text-fill: white;"/>
        <Button text="8" onAction="#handleNumber" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #3c3f41; -fx-text-fill: white;"/>
        <Button text="9" onAction="#handleNumber" GridPane.columnIndex="2" GridPane.rowIndex="0" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #3c3f41; -fx-text-fill: white;"/>
        <Button text="/" onAction="#handleOperator" GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #f0a500; -fx-text-fill: white;"/>

        <!-- Row 1 -->
        <Button text="4" onAction="#handleNumber" GridPane.columnIndex="0" GridPane.rowIndex="1" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #3c3f41; -fx-text-fill: white;"/>
        <Button text="5" onAction="#handleNumber" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #3c3f41; -fx-text-fill: white;"/>
        <Button text="6" onAction="#handleNumber" GridPane.columnIndex="2" GridPane.rowIndex="1" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #3c3f41; -fx-text-fill: white;"/>
        <Button text="-" onAction="#handleOperator" GridPane.columnIndex="3" GridPane.rowIndex="1" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #f0a500; -fx-text-fill: white;"/>

        <!-- Row 2 -->
        <Button text="1" onAction="#handleNumber" GridPane.columnIndex="0" GridPane.rowIndex="2" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #3c3f41; -fx-text-fill: white;"/>
        <Button text="2" onAction="#handleNumber" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #3c3f41; -fx-text-fill: white;"/>
        <Button text="3" onAction="#handleNumber" GridPane.columnIndex="2" GridPane.rowIndex="2" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #3c3f41; -fx-text-fill: white;"/>
        <Button text="+" onAction="#handleOperator" GridPane.columnIndex="3" GridPane.rowIndex="2" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #f0a500; -fx-text-fill: white;"/>

        <!-- Row 3 -->
        <Button text="C" onAction="#handleClear" GridPane.columnIndex="0" GridPane.rowIndex="3" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #c0392b; -fx-text-fill: white;"/>
        <Button text="0" onAction="#handleNumber" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #3c3f41; -fx-text-fill: white;"/>
        <Button text="=" onAction="#handleEquals" GridPane.columnIndex="2" GridPane.rowIndex="3" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button text="*" onAction="#handleOperator" GridPane.columnIndex="3" GridPane.rowIndex="3" prefWidth="70" prefHeight="60" style="-fx-font-size: 18px; -fx-background-color: #f0a500; -fx-text-fill: white;"/>

    </GridPane>
</VBox>